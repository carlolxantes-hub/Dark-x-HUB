local function applyCollisionLogic(obj)
    if not obj:IsA("BasePart") then return end
    local name = obj.Name:lower()
    local isCar = false
    local parent = obj
    while parent do
        if parent.Name:lower():find(carKeyword) then isCar = true break end
        parent = parent.Parent
    end
    if isCar then obj.CanCollide = not antiCarSit end
end

