                    local modelo = hit.Instance:FindFirstAncestorOfClass("Model")
                    local jogador = jogadores:GetPlayerFromCharacter(modelo)
                    if jogador and jogador ~= eu then
                        FlingBallTool(jogador)
                    end
                end
            end
        end)
    end
})



